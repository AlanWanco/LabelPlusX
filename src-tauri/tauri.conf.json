{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LabelPlusX",
  "version": "0.1.0",
  "identifier": "com.labelplusx.app",
  "build": {
    "beforeDevCommand": "node scripts/tauri-dev-server.mjs",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LabelPlusX",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
